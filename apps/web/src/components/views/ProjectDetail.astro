---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PageHero from "../PageHero.astro";
import { getPath, useTranslations, type Locale } from "../../i18n/utils";
import { categoryHref, serviceHref } from "../../lib/urls";
import { categoryName, type ProjectCategoryKey } from "../../i18n/categories";
import type { TopicKey } from "../../i18n/topics";
import TopicChips from "../TopicChips.astro";
import RelatedContent from "../RelatedContent.astro";

interface Props {
  entry: CollectionEntry<"projects">;
  alternates: { locale: Locale; href: string }[];
}

const { entry, alternates } = Astro.props;
const locale = entry.data.locale as Locale;
const cat = entry.data.category as ProjectCategoryKey;
const topics = entry.data.topics as TopicKey[];
const t = useTranslations(locale);
const { Content } = await render(entry);

// Enlaza los servicios aplicados (por key) a su landing en el mismo idioma.
const allServices = await getCollection("services");
const serviceLinks = entry.data.services
  .map((key) => allServices.find((s) => s.data.key === key && s.data.locale === locale))
  .filter((s): s is NonNullable<typeof s> => Boolean(s))
  .map((s) => ({ title: s.data.title, href: serviceHref(locale, s.data.slug) }));
---

<Layout
  locale={locale}
  activeNav="portfolio"
  title={entry.data.title}
  description={entry.data.description}
  ogType="article"
  image={entry.data.ogImage ?? entry.data.image}
  alternates={alternates}
  heroOverlay
  breadcrumbs={[
    { label: t("nav.home"), href: getPath(locale, "home") },
    { label: t("portfolio.title"), href: getPath(locale, "portfolio") },
    { label: categoryName(locale, cat), href: categoryHref(locale, cat) },
    { label: entry.data.title },
  ]}
>
  <PageHero
    slot="hero"
    eyebrow={categoryName(locale, cat)}
    title={entry.data.title}
    subtitle={entry.data.description}
    image={entry.data.image}
  />

  {
    entry.data.results.length > 0 && (
      <section
        data-reveal
        class="mb-12 grid grid-cols-2 gap-px overflow-hidden rounded-3xl border border-slate-200 bg-slate-200 sm:grid-cols-3 lg:grid-cols-4"
        aria-label={locale === "es" ? "Resultados" : "Results"}
      >
        {entry.data.results.map((r) => (
          <div class="bg-white px-5 py-7 text-center">
            <div class="u-display text-3xl font-bold leading-none tabular-nums text-brand-600 sm:text-4xl">
              {r.value}
            </div>
            <div class="mt-2 text-sm font-medium text-slate-500">{r.label}</div>
          </div>
        ))}
      </section>
    )
  }

  <div class="grid gap-10 lg:grid-cols-[1fr_320px] lg:gap-16">
    <article class="min-w-0 max-w-2xl">
      <div class="prose-bezenti">
        <Content />
      </div>

      {
        entry.data.gallery.length > 0 && (
          <div class="mt-10 grid gap-6 sm:grid-cols-2">
            {entry.data.gallery.map((g, i) => (
              <figure
                data-reveal
                style={`--reveal-delay:${(i % 2) * 80}ms`}
                class:list={[i === 0 && entry.data.gallery.length > 1 && "sm:col-span-2"]}
              >
                <img
                  src={g.src}
                  alt={g.alt}
                  width="1000"
                  height="700"
                  loading="lazy"
                  decoding="async"
                  class:list={[
                    "w-full rounded-2xl border border-slate-200 object-cover",
                    i === 0 && entry.data.gallery.length > 1 ? "aspect-[16/9]" : "aspect-[10/7]",
                  ]}
                />
                {g.caption && (
                  <figcaption class="mt-2 text-sm text-slate-500">{g.caption}</figcaption>
                )}
              </figure>
            ))}
          </div>
        )
      }
    </article>

    {/* Ficha técnica fija: datos + servicios aplicados + temas + CTA. */}
    <aside class="lg:sticky lg:top-28 lg:self-start">
      <div class="rounded-3xl border border-slate-200 bg-white p-7 shadow-sm">
        <dl class="space-y-4">
          {entry.data.client && (
            <div>
              <dt class="text-xs font-medium uppercase tracking-wide text-slate-400">{t("portfolio.client")}</dt>
              <dd class="mt-0.5 font-semibold text-slate-900">{entry.data.client}</dd>
            </div>
          )}
          {entry.data.year && (
            <div>
              <dt class="text-xs font-medium uppercase tracking-wide text-slate-400">{t("portfolio.year")}</dt>
              <dd class="mt-0.5 font-semibold text-slate-900">{entry.data.year}</dd>
            </div>
          )}
        </dl>

        {serviceLinks.length > 0 && (
          <div class="mt-5 border-t border-slate-200 pt-5">
            <p class="text-xs font-medium uppercase tracking-wide text-slate-400">
              {locale === "es" ? "Servicios aplicados" : "Services applied"}
            </p>
            <div class="mt-2 flex flex-wrap gap-2">
              {serviceLinks.map((s) => (
                <a
                  href={s.href}
                  class="rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600 transition-colors hover:border-brand-600 hover:text-brand-600"
                >
                  {s.title}
                </a>
              ))}
            </div>
          </div>
        )}

        {topics.length > 0 && (
          <div class="mt-5 border-t border-slate-200 pt-5">
            <p class="mb-2 text-xs font-medium uppercase tracking-wide text-slate-400">{t("topics.label")}</p>
            <TopicChips locale={locale} topics={topics} />
          </div>
        )}

        {entry.data.url && (
          <a
            href={entry.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-full border border-slate-300 px-6 py-3 font-medium text-slate-900 transition-colors hover:border-brand-600 hover:text-brand-600"
          >
            {locale === "es" ? "Ver sitio en vivo" : "Visit live site"}
            <span aria-hidden="true">↗</span>
          </a>
        )}

        <a
          href={getPath(locale, "contact")}
          class:list={[
            "inline-flex w-full items-center justify-center gap-2 rounded-full bg-brand-600 px-6 py-3 font-medium text-white transition-colors hover:bg-brand-500",
            entry.data.url ? "mt-3" : "mt-6",
          ]}
        >
          {t("cta.discuss")}
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </aside>
  </div>

  <RelatedContent locale={locale} topics={topics} exclude={{ type: "project", id: entry.id }} />
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../PageHero.astro";
import WorldOfficesMap from "../WorldOfficesMap.astro";
import { getAlternateLinks, getPath, useTranslations, type Locale } from "../../i18n/utils";
import { officesByCountry } from "../../lib/offices";
import { contact, whatsappHref, emailHref } from "../../lib/contact";
import { faqs } from "../../lib/faq";
import { ContactForm } from "../ContactForm.tsx";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const groups = officesByCountry();

const labels = {
  name: t("contact.name"),
  email: t("contact.email"),
  message: t("contact.message"),
  send: t("contact.send"),
  sending: t("contact.sending"),
  success: t("contact.success"),
  error: t("contact.error"),
};

// Promesas (lista de objetos → se quedan en la vista).
const promises: Record<Locale, { title: string; body: string }[]> = {
  es: [
    { title: "Respuesta en 24 h", body: "Te contestamos en menos de un día laborable, sin formularios eternos." },
    { title: "Hablas con quien construye", body: "Sin intermediarios: tratas directamente con el equipo del proyecto." },
    { title: "Presupuesto claro", body: "Te decimos qué cuesta y por qué, sin sorpresas ni letra pequeña." },
  ],
  en: [
    { title: "Reply within 24 h", body: "We get back to you in under one business day, no endless forms." },
    { title: "Talk to the people who build", body: "No middlemen: you deal directly with the project team." },
    { title: "Clear quote", body: "We tell you what it costs and why, no surprises or fine print." },
  ],
};
const promise = promises[locale];

// FAQPage JSON-LD: habilita el rich snippet de preguntas frecuentes en Google.
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q[locale],
    acceptedAnswer: { "@type": "Answer", text: f.a[locale] },
  })),
};
---

<Layout
  locale={locale}
  activeNav="contact"
  title={t("contact.title")}
  description={t("contact.subtitle")}
  alternates={getAlternateLinks("contact")}
  heroOverlay
  breadcrumbs={[
    { label: t("nav.home"), href: getPath(locale, "home") },
    { label: t("contact.title") },
  ]}
>
  <PageHero
    slot="hero"
    title={t("contact.title")}
    subtitle={t("contact.subtitle")}
    image="/images/banners/contact.jpg"
  />

  {/* Split: promesa (panel oscuro) + formulario (panel claro). */}
  <section class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:gap-10">
    <div data-reveal class="rounded-3xl bg-slate-900 p-8 text-white sm:p-10">
      <h2 class="u-display text-2xl font-bold sm:text-3xl">{t("contact.writeUs")}</h2>
      <p class="mt-3 text-slate-300">{t("contact.subtitle")}</p>
      <ul class="mt-8 space-y-6">
        {
          promise.map((p, i) => (
            <li class="flex gap-4">
              <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white/5 text-sm font-bold text-brand-300 ring-1 ring-white/10">
                {i + 1}
              </span>
              <div>
                <h3 class="font-semibold">{p.title}</h3>
                <p class="mt-1 text-sm leading-relaxed text-slate-400">{p.body}</p>
              </div>
            </li>
          ))
        }
      </ul>

      {/* Contacto directo: WhatsApp + correo. Para muchos visitantes (sobre
          todo en móvil) es el camino de conversión más corto. */}
      <div class="mt-8 border-t border-white/10 pt-8">
        <p class="text-sm font-semibold uppercase tracking-wide text-brand-300">
          {t("contact.methods.title")}
        </p>
        <div class="mt-4 space-y-3">
          <a
            href={whatsappHref(locale)}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 rounded-2xl bg-white/5 px-4 py-3 ring-1 ring-white/10 transition-colors hover:bg-white/10"
          >
            <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[#25D366] text-white">
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
                <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.512 5.26l-.999 3.648 3.737-.98zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z" />
              </svg>
            </span>
            <span>
              <span class="block font-semibold text-white">{t("contact.methods.whatsapp")}</span>
              <span class="block text-sm text-slate-400">{t("contact.methods.whatsappBody")}</span>
            </span>
          </a>
          <a
            href={emailHref(locale)}
            class="flex items-center gap-3 rounded-2xl bg-white/5 px-4 py-3 ring-1 ring-white/10 transition-colors hover:bg-white/10"
          >
            <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-brand-600 text-white">
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
                <rect x="3" y="5" width="18" height="14" rx="2" />
                <path d="m3 7 9 6 9-6" />
              </svg>
            </span>
            <span>
              <span class="block font-semibold text-white">{t("contact.methods.email")}</span>
              <span class="block text-sm text-slate-400">{contact.email}</span>
            </span>
          </a>
        </div>
      </div>
    </div>

    <div data-reveal style="--reveal-delay:100ms" class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
      <ContactForm client:load labels={labels} />
    </div>
  </section>

  {/* Sedes: mapa + lista por país, en banda separada. */}
  <section class="mt-16 border-t border-slate-200 pt-16">
    <div data-reveal>
      <h2 class="u-display text-2xl font-bold text-slate-900 sm:text-3xl">{t("contact.offices")}</h2>
      <p class="mt-2 max-w-2xl text-slate-600">{t("contact.officesSubtitle")}</p>
    </div>

    <div class="mt-8 grid items-center gap-10 lg:grid-cols-2">
      <div data-reveal="scale">
        <WorldOfficesMap locale={locale} />
      </div>

      <ul class="grid gap-4 sm:grid-cols-2">
        {
          groups.map((g, i) => (
            <li
              data-reveal
              style={`--reveal-delay:${(i % 2) * 80}ms`}
              class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
            >
              <h3 class="font-semibold text-slate-900">{g.name[locale]}</h3>
              <ul class="mt-2 space-y-1.5">
                {g.cities.map((c) => (
                  <li class="flex items-center gap-2 text-sm text-slate-600">
                    <span class="h-2 w-2 shrink-0 rounded-full bg-coral-500" />
                    {c.city}
                  </li>
                ))}
              </ul>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* FAQ: rebate objeciones antes del contacto y alimenta el rich snippet de
      Google. Acordeón nativo <details>: accesible y sin JS. */}
  <section class="mt-16 border-t border-slate-200 pt-16">
    <div data-reveal class="max-w-2xl">
      <h2 class="u-display text-2xl font-bold text-slate-900 sm:text-3xl">{t("contact.faq.title")}</h2>
      <p class="mt-2 text-slate-600">{t("contact.faq.subtitle")}</p>
    </div>
    <div class="mt-8 divide-y divide-slate-200 border-t border-slate-200">
      {
        faqs.map((f) => (
          <details class="group py-5">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-semibold text-slate-900 marker:hidden">
              {f.q[locale]}
              <span
                class="shrink-0 text-2xl font-normal leading-none text-brand-600 transition-transform group-open:rotate-45"
                aria-hidden="true"
              >
                +
              </span>
            </summary>
            <p class="mt-3 max-w-2xl leading-relaxed text-slate-600">{f.a[locale]}</p>
          </details>
        ))
      }
    </div>
  </section>

  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(faqJsonLd)}
  />
</Layout>

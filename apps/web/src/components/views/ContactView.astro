---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../PageHero.astro";
import WorldOfficesMap from "../WorldOfficesMap.astro";
import { getAlternateLinks, getPath, useTranslations, type Locale } from "../../i18n/utils";
import { officesByCountry } from "../../lib/offices";
import { ContactForm } from "../ContactForm.tsx";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const groups = officesByCountry();

const labels = {
  name: t("contact.name"),
  email: t("contact.email"),
  message: t("contact.message"),
  send: t("contact.send"),
  sending: t("contact.sending"),
  success: t("contact.success"),
  error: t("contact.error"),
};

// Promesas (lista de objetos → se quedan en la vista).
const promises: Record<Locale, { title: string; body: string }[]> = {
  es: [
    { title: "Respuesta en 24 h", body: "Te contestamos en menos de un día laborable, sin formularios eternos." },
    { title: "Hablas con quien construye", body: "Sin intermediarios: tratas directamente con el equipo del proyecto." },
    { title: "Presupuesto claro", body: "Te decimos qué cuesta y por qué, sin sorpresas ni letra pequeña." },
  ],
  en: [
    { title: "Reply within 24 h", body: "We get back to you in under one business day, no endless forms." },
    { title: "Talk to the people who build", body: "No middlemen: you deal directly with the project team." },
    { title: "Clear quote", body: "We tell you what it costs and why, no surprises or fine print." },
  ],
};
const promise = promises[locale];
---

<Layout
  locale={locale}
  activeNav="contact"
  title={t("contact.title")}
  description={t("contact.subtitle")}
  alternates={getAlternateLinks("contact")}
  heroOverlay
  breadcrumbs={[
    { label: t("nav.home"), href: getPath(locale, "home") },
    { label: t("contact.title") },
  ]}
>
  <PageHero
    slot="hero"
    title={t("contact.title")}
    subtitle={t("contact.subtitle")}
    image="/images/banners/contact.jpg"
  />

  {/* Split: promesa (panel oscuro) + formulario (panel claro). */}
  <section class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:gap-10">
    <div data-reveal class="rounded-3xl bg-slate-900 p-8 text-white sm:p-10">
      <h2 class="u-display text-2xl font-bold sm:text-3xl">{t("contact.writeUs")}</h2>
      <p class="mt-3 text-slate-300">{t("contact.subtitle")}</p>
      <ul class="mt-8 space-y-6">
        {
          promise.map((p, i) => (
            <li class="flex gap-4">
              <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white/5 text-sm font-bold text-brand-300 ring-1 ring-white/10">
                {i + 1}
              </span>
              <div>
                <h3 class="font-semibold">{p.title}</h3>
                <p class="mt-1 text-sm leading-relaxed text-slate-400">{p.body}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>

    <div data-reveal style="--reveal-delay:100ms" class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
      <ContactForm client:load labels={labels} />
    </div>
  </section>

  {/* Sedes: mapa + lista por país, en banda separada. */}
  <section class="mt-16 border-t border-slate-200 pt-16">
    <div data-reveal>
      <h2 class="u-display text-2xl font-bold text-slate-900 sm:text-3xl">{t("contact.offices")}</h2>
      <p class="mt-2 max-w-2xl text-slate-600">{t("contact.officesSubtitle")}</p>
    </div>

    <div class="mt-8 grid items-center gap-10 lg:grid-cols-2">
      <div data-reveal="scale">
        <WorldOfficesMap locale={locale} />
      </div>

      <ul class="grid gap-4 sm:grid-cols-2">
        {
          groups.map((g, i) => (
            <li
              data-reveal
              style={`--reveal-delay:${(i % 2) * 80}ms`}
              class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition-shadow hover:shadow-md"
            >
              <h3 class="font-semibold text-slate-900">{g.name[locale]}</h3>
              <ul class="mt-2 space-y-1.5">
                {g.cities.map((c) => (
                  <li class="flex items-center gap-2 text-sm text-slate-600">
                    <span class="h-2 w-2 shrink-0 rounded-full bg-coral-500" />
                    {c.city}
                  </li>
                ))}
              </ul>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Layout>

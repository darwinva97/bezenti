---
/**
 * Hero de banner para páginas interiores: imagen de fondo a sangre completa con
 * capa oscura para contraste, título y subtítulo en blanco. El header
 * transparente se superpone aquí (ver `heroOverlay` en Layout). El `pt` superior
 * reserva el espacio del header fijo. Acepta contenido extra por el slot.
 */
interface Props {
  title: string;
  subtitle?: string;
  /** Texto pequeño sobre el título (sección, categoría, tipo…). */
  eyebrow?: string;
  /** Imagen de fondo (ruta del sitio). Si falta, queda el fondo oscuro liso. */
  image?: string;
  /** Centrar el contenido (por defecto alineado a la izquierda). */
  center?: boolean;
}

const { title, subtitle, eyebrow, image, center = false } = Astro.props;
---

<section
  class:list={[
    "relative isolate overflow-hidden bg-slate-950 text-white",
    center && "text-center",
  ]}
>
  {
    image && (
      <img
        src={image}
        alt=""
        aria-hidden="true"
        class="absolute inset-0 -z-10 h-full w-full object-cover opacity-50"
      />
    )
  }
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-b from-slate-950/85 via-slate-950/70 to-slate-950/90"
  >
  </div>
  <div class="mx-auto max-w-7xl px-4 pb-12 pt-28 sm:px-6 sm:pb-16 sm:pt-32 lg:px-8">
    {eyebrow && (
      <p class="text-sm font-medium uppercase tracking-wide text-brand-300">{eyebrow}</p>
    )}
    <h1 class="u-display mt-1 text-3xl font-bold sm:text-4xl">{title}</h1>
    {subtitle && <p class="mt-3 max-w-2xl text-lg leading-relaxed text-slate-200">{subtitle}</p>}
    <slot />
  </div>
</section>

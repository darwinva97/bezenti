---
/**
 * Rejilla de contenido relacionado de UN tipo (proyectos o posts), con su
 * propio título de sección. Se alimenta de `getRelatedProjects` /
 * `getRelatedPosts` (puntuados por categoría + tags). Si no hay elementos, no
 * renderiza nada.
 */
import MediaCard from "./MediaCard.astro";
import type { RelatedItem } from "../lib/related";

interface Props {
  title: string;
  items: RelatedItem[];
}

const { title, items } = Astro.props;
---

{
  items.length > 0 && (
    <section class="mt-12 border-t border-slate-200 pt-8">
      <h2 class="u-display text-xl font-bold text-slate-900 sm:text-2xl">{title}</h2>
      <div class="mt-5 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {items.map((r, i) => (
          <MediaCard
            href={r.href}
            title={r.title}
            description={r.description}
            image={r.cardImage ?? r.image}
            imageAlt={r.imageAlt}
            reveal
            revealDelay={(i % 3) * 80}
          />
        ))}
      </div>
    </section>
  )
}
